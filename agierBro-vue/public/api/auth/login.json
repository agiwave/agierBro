{
  "username": "",
  "password": "",
  "remember": false,
  "_schema": {
    "type": "object",
    "title": "登录",
    "description": "使用账号密码登录系统",
    "semantic": "content",
    "properties": {
      "username": {
        "type": "string",
        "title": "用户名",
        "required": true,
        "placeholder": "请输入用户名",
        "minLength": 3,
        "maxLength": 20
      },
      "password": {
        "type": "string",
        "title": "密码",
        "format": "password",
        "required": true,
        "placeholder": "请输入密码",
        "minLength": 6
      },
      "remember": {
        "type": "boolean",
        "title": "记住我",
        "default": false
      }
    },
    "tools": [
      {
        "name": "login",
        "description": "登录系统",
        "parameters": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          },
          "required": ["username", "password"]
        },
        "protocol": "http",
        "method": "POST",
        "url": "/api/auth/login",
        "onSuccess": [
          { "type": "message", "message": "登录成功", "level": "success" },
          { "type": "navigate", "target": "/" }
        ],
        "onError": [
          { "type": "message", "message": "用户名或密码错误", "level": "error" }
        ]
      }
    ]
  }
}
