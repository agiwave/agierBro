{
  "_schema": {
    "in": {
      "type": "object",
      "title": "登录输入",
      "properties": {
        "username": {
          "type": "string",
          "title": "用户名",
          "required": true,
          "placeholder": "请输入用户名",
          "minLength": 3,
          "maxLength": 20
        },
        "password": {
          "type": "string",
          "title": "密码",
          "format": "password",
          "required": true,
          "placeholder": "请输入密码",
          "minLength": 6
        },
        "remember": {
          "type": "boolean",
          "title": "记住我",
          "default": false
        }
      }
    },
    "out": {
      "type": "object",
      "title": "登录结果",
      "properties": {
        "access_token": { "type": "string", "title": "访问令牌" },
        "refresh_token": { "type": "string", "title": "刷新令牌" },
        "message": { "type": "string", "title": "消息" }
      }
    }
  },
  "protocol": "http",
  "method": "POST",
  "url": "/api/auth/login.json"
}
