{
  "_schema": {
    "in": {
      "type": "object",
      "title": "创建用户",
      "properties": {
        "username": { 
          "type": "string", 
          "title": "用户名",
          "required": true,
          "minLength": 3,
          "maxLength": 20,
          "placeholder": "请输入用户名"
        },
        "email": { 
          "type": "string", 
          "title": "邮箱", 
          "format": "email",
          "required": true,
          "placeholder": "请输入邮箱地址"
        },
        "password": { 
          "type": "string", 
          "title": "密码", 
          "format": "password",
          "required": true,
          "minLength": 6,
          "placeholder": "请输入密码"
        },
        "role": { 
          "type": "string", 
          "title": "角色",
          "required": true,
          "enum": [
            { "value": "管理员", "label": "管理员" },
            { "value": "编辑", "label": "编辑" },
            { "value": "评审", "label": "评审" }
          ]
        }
      }
    },
    "out": {
      "type": "object",
      "title": "创建结果",
      "properties": {
        "id": { "type": "string", "title": "用户 ID" },
        "message": { "type": "string", "title": "消息" }
      }
    }
  },
  "protocol": "http",
  "method": "POST",
  "url": "/api/users/index.json",
  "_tools": [
    {
      "name": "cancel",
      "displayName": "取消",
      "description": "取消创建",
      "protocol": "navigate",
      "target": "/users"
    }
  ]
}
